# MQTT Configuration Template
# Copy this file to .env and fill in the actual values

MQTT_SERVER=your-broker-address.net
MQTT_PORT=8883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password
MQTT_CLIENT_ID=BackendClient
MQTT_TOPIC=Equipe3/#

# Path to SSL/TLS certificates (relative to the backend root)
MQTT_CLIENT_CERT=certs/client.pem
MQTT_CLIENT_KEY=certs/client.key
